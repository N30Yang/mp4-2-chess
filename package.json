{
  "name": "chess-mosaic",
  "version": "1.0.0",
  "description": "Convert an MP4 into a chess-piece mosaic video via ffmpeg + sharp",
  "type": "module",
  "bin": {
    "chess-mosaic": "cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "gen-pieces": "node scripts/gen-pieces.js",
    "build:all": "pkg . --targets node18-macos-x64,node18-macos-arm64,node18-win-x64,node18-linux-x64 --out-path dist",
    "build:mac": "pkg . --targets node18-macos-arm64 --output dist/chess-mosaic-macos",
    "build:win": "pkg . --targets node18-win-x64 --output dist/chess-mosaic-win.exe",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/chess-mosaic-linux"
  },
  "engines": {
    "node": ">=18"
  },
  "pkg": {
    "assets": [
      "pieces/*.png",
      "node_modules/ffmpeg-static/ffmpeg*",
      "node_modules/ffprobe-static/bin/**/*",
      "node_modules/@img/**/*"
    ],
    "targets": [
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0"
  }
}
