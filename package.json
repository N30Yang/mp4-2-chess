{
  "name": "chess-to-mp4",
  "version": "1.0.0",
  "description": "Chess To MP4 convert an MP4 into a chess-piece video via ffmpeg + sharp",
  "type": "module",
  "bin": {
    "chess-to-mp4": "cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "gen-pieces": "node scripts/gen-pieces.js",
    "build:all": "pkg . --targets node20-macos-x64,node20-macos-arm64,node20-win-x64,node20-linux-x64 --out-path dist",
    "build:win": "pkg . --targets node20-win-x64 --output dist/chess-to-mp4-win.exe",
    "build:linux": "pkg . --targets node20-linux-x64 --output dist/chess-to-mp4-linux"
  },
  "engines": {
    "node": ">=20"
  },
  "pkg": {
    "assets": [
      "pieces/*.png",
      "node_modules/ffmpeg-static/ffmpeg*",
      "node_modules/ffprobe-static/bin/**/*",
      "node_modules/@img/**/*"
    ],
    "targets": [
      "node20-win-x64",
      "node20-linux-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0"
  }
}